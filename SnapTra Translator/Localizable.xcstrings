    "Drag the handle to reorder lookup priority. The first enabled dictionary will be queried first." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drag the handle to reorder lookup priority. The first enabled dictionary will be queried first."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrastre el control para reordenar la prioridad de búsqueda. El primer diccionario habilitado se consultará primero."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ハンドルをドラッグして検索優先順位を並べ替えます。最初に有効になった辞書が最初に検索されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "핸들을 드래그하여 조회 우선순위를 재정렬하세요. 첫 번째로 활성화된 사전이 먼저 조회됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拖动手柄以重新排序查询优先级。第一个启用的字典将首先被查询。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拖動手柄以重新排序查詢優先級。第一個啟用的字典將首先被查詢。"
          }
        }
      }
    },

    "The language pack for %@ → %@ translation is not installed. Please download the required language packs in System Settings > General > Language & Region > Translation Languages." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The language pack for %1$@ → %2$@ translation is not installed. Please download the required language packs in System Settings > General > Language & Region > Translation Languages."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ → %2$@ の翻訳用言語パックがインストールされていません。システム設定 > 一般 > 言語と地域 > 翻訳言語から必要な言語パックをダウンロードしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ → %2$@ 번역용 언어 팩이 설치되지 않았습니다. 시스템 설정 > 일반 > 언어 및 지역 > 번역 언어에서 필요한 언어 팩을 다운로드하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ → %2$@ 翻译所需的语言包尚未安装。请在系统设置 > 通用 > 语言与地区 > 翻译语言中下载所需的语言包。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ → %2$@ 翻譯所需的語言包尚未安裝。請在系統設定 > 一般 > 語言與地區 > 翻譯語言中下載所需的語言包。"
          }
        }
      }
    },
    "This will delete all word records. This action cannot be undone." : {
